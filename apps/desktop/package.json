{
  "name": "desktop",
  "private": true,
  "version": "0.1.27",
  "description": "Cowork desktop app",
  "author": {
    "name": "Max Weinbach",
    "email": "max@weinbach.co"
  },
  "homepage": "https://github.com/mweinbach/agent-coworker",
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "bun run --cwd ../.. build:desktop-resources && electron-vite dev",
    "build": "bun run --cwd ../.. build:desktop-resources && electron-vite build && electron-builder --config electron-builder.yml",
    "build:dir": "bun run --cwd ../.. build:desktop-resources && electron-vite build && electron-builder --dir --config electron-builder.yml",
    "preview": "electron-vite preview",
    "test": "bun test"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@radix-ui/react-checkbox": "^1.3.3",
