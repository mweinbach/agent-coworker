{
  "name": "desktop",
  "private": true,
  "version": "0.1.48",
  "description": "Cowork desktop app",
  "author": {
    "name": "Max Weinbach",
    "email": "max@weinbach.co"
  },
  "homepage": "https://github.com/mweinbach/agent-coworker",
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "electron-vite": "bun --bun ../../node_modules/electron-vite/bin/electron-vite.js",
    "dev": "bun run --cwd ../.. build:desktop-resources && bun run electron-vite -- dev",
    "build": "bun run --cwd ../.. build:desktop-resources && bun run electron-vite -- build && electron-builder --config electron-builder.yml",
    "build:dir": "bun run --cwd ../.. build:desktop-resources && bun run electron-vite -- build && electron-builder --dir --config electron-builder.yml",
    "preview": "bun run electron-vite -- preview",
    "web": "bun --cwd ../.. build:desktop-resources && bun vite --config vite.config.web.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.3",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "mammoth": "^1.12.0",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^10.0.1",
    "react-hook-form": "^7.76.0",
    "react-resizable-panels": "^4.11.1",
    "recharts": "3.8.1",
    "sonner": "^2.0.7",
    "vaul": "^1.1.2",
    "ws": "^8.20.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@formkit/auto-animate": "^0.9.0",
    "@react-grab/mcp": "^0.1.34",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "ai-elements": "^1.9.0",
    "clsx": "^2.1.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.10.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^6.0.0-beta.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "react-grab": "^0.1.34",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "zustand": "^5.0.13"
  }
}
