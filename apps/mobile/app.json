{
  "expo": {
    "name": "Cowork Mobile",
    "slug": "cowork-mobile",
    "scheme": "cowork-mobile",
    "version": "0.1.0",
    "autolinking": {
      "nativeModulesDir": "./modules"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#171d13"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.weinbach.cowork.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Cowork Mobile uses the camera to scan remote access pairing QR codes."
      }
    },
    "android": {
      "package": "co.weinbach.cowork.mobile",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#171d13"
      },
      "permissions": ["android.permission.CAMERA"]
    },
    "plugins": ["expo-router", "expo-dev-client", "expo-camera", "expo-secure-store", "expo-font"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
