{
  "name": "agent-coworker",
  "version": "1.1.2",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "workspaces": [
    "apps/desktop",
    "packages/*"
  ],
  "bin": {
    "cowork": "./src/index.ts"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/server/jsonrpc/codegen.ts",
    "!src/server/jsonrpc/schema.ts",
    "!src/server/jsonrpc/schema.provider.ts",
    "!src/server/jsonrpc/schema.skills.ts",
    "!src/server/jsonrpc/schema.backups.ts",
    "!src/server/jsonrpc/schema.memory.ts",
    "!src/server/jsonrpc/schema.mcp.ts",
    "!src/server/jsonrpc/schema.misc.ts",
    "!src/shared/jsonrpcControlSchemas.ts",
    "!src/server/agents/DelegateRunner.ts",
    "!src/client/modelStreamReplay.ts",
    "!src/shared/displayCitationMarkers.ts",
    "!src/shared/askPrompt.ts",
    "!src/runtime/openaiEventStream.ts",
    "config/**/*",
    "prompts/**/*",
    "!prompts/system-models/.research",
    "scripts/build_cowork_server_binary.ts",
    "scripts/setup_codex_primary_runtime.ts",
    "scripts/postinstall.ts",
    "scripts/releaseBuildUtils.ts",
    "skills/**/*",
    "!skills/**/__pycache__",
    "!skills/**/*.pyc",
    "!skills/**/dev/**",
    "README.md"
  ],
  "scripts": {
    "start": "cd apps/desktop && bun run dev",
    "cli": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "serve": "bun src/server/index.ts",
    "setup:codex-runtime": "bun scripts/setup_codex_primary_runtime.ts",
    "build:server-binary": "bun scripts/build_cowork_server_binary.ts",
    "desktop:dev": "cd apps/desktop && bun run dev",
    "desktop:web": "bun apps/desktop/scripts/start_web_dev.ts",
    "desktop:build": "cd apps/desktop && bun run build",
    "app:mobile:dev": "cd apps/mobile && npx expo start --dev-client",
    "app:mobile:ios": "cd apps/mobile && npx expo run:ios",
    "app:mobile:android": "cd apps/mobile && npx expo run:android",
    "app:mobile:xcode": "bun scripts/open_xcode_workspace.ts",
    "app:mobile:typecheck": "cd apps/mobile && bun run typecheck",
    "build:desktop-resources": "bun scripts/build_desktop_resources.ts",
    "docs:check": "bun packages/harness/src/check_docs.ts",
    "docs:generate-jsonrpc": "bun packages/harness/src/generate_ws_jsonrpc_schema.ts",
    "harness:run": "bun packages/harness/src/run_raw_agent_loops.ts --report-only",
    "test": "bun test",
    "test:stable": "bun packages/harness/src/run_tests_stable.ts",
    "clean": "bun scripts/clean.ts",
    "typecheck": "bunx tsc --noEmit && bun run --cwd packages/harness typecheck && bunx tsc --noEmit -p apps/desktop/tsconfig.json",
    "typecheck:desktop": "bunx tsc --noEmit -p apps/desktop/tsconfig.json",
    "lint": "bunx biome lint .",
    "format": "bunx biome format .",
    "format:write": "bunx biome format --write .",
    "check": "bunx biome check .",
    "check:write": "bunx biome check --write ."
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.1053.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1053.0",
    "@earendil-works/pi-ai": "^0.75.4",
    "@google/genai": "^2.6.0",
    "@langfuse/otel": "^5.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@peculiar/x509": "^2.0.0",
    "@react-pdf/renderer": "^4.5.1",
    "docx": "^9.6.1",
    "fast-glob": "^3.3.3",
    "jsdom": "^29.1.1",
    "partial-json": "^0.1.7",
    "proxy-agent": "^8.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reflect-metadata": "^0.2.2",
    "remark-parse": "^11.0.0",
    "turndown": "^7.2.4",
    "unified": "^11.0.5",
    "unofficial-antigravity-sdk": "^1.0.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "4.4.3"
  },
  "optionalDependencies": {
    "@microsoft/windows-ai-electron": "^0.2.0",
    "tsfm-sdk": "^0.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
