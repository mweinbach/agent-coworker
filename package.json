{
  "name": "agent-coworker",
  "version": "1.2.23",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "workspaces": [
    "apps/desktop",
    "packages/*"
  ],
  "bin": {
    "cowork": "./src/index.ts"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/server/jsonrpc/codegen.ts",
    "!src/server/jsonrpc/schema.ts",
    "!src/server/jsonrpc/schema.provider.ts",
    "!src/server/jsonrpc/schema.skills.ts",
    "!src/server/jsonrpc/schema.memory.ts",
    "!src/server/jsonrpc/schema.mcp.ts",
    "!src/server/jsonrpc/schema.misc.ts",
    "!src/server/agents/DelegateRunner.ts",
    "!src/client/modelStreamReplay.ts",
    "!src/shared/displayCitationMarkers.ts",
    "!src/shared/askPrompt.ts",
    "config/**/*",
    "prompts/**/*",
    "!prompts/system-models/.research",
    "scripts/build_cowork_server_binary.ts",
    "scripts/setup_cowork_runtime.ts",
    "scripts/postinstall.ts",
    "scripts/releaseBuildUtils.ts",
    "skills/**/*",
    "!skills/**/__pycache__",
    "!skills/**/*.pyc",
    "!skills/**/dev/**",
    "README.md"
  ],
  "scripts": {
    "start": "cd apps/desktop && bun run dev",
    "cli": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "serve": "bun src/server/index.ts",
    "dev:rpc": "bun --watch src/server/index.ts --host 127.0.0.1 --port 7337",
    "desktop:demo": "COWORK_DEMO_MODE=1 bun run start",
    "setup:runtime": "bun scripts/setup_cowork_runtime.ts",
    "build:server-binary": "bun scripts/build_cowork_server_binary.ts",
    "desktop:dev": "cd apps/desktop && bun run dev",
    "desktop:web": "bun apps/desktop/scripts/start_web_dev.ts",
    "web:dev": "bun apps/desktop/scripts/start_web_dev.ts",
    "desktop:build": "cd apps/desktop && bun run build",
    "desktop:quality:build": "bun run --cwd apps/desktop electron-vite -- build --config quality-gates/electron.vite.config.ts",
    "desktop:quality:test": "playwright test --config apps/desktop/quality-gates/playwright.config.ts",
    "desktop:quality": "bun run desktop:quality:build && bun run desktop:quality:test && bun run desktop:quality:screenshot:check",
    "desktop:quality:native-first-paint": "bun run desktop:quality:build && bun run desktop:quality:test native-first-paint.pw.ts",
    "desktop:quality:update": "bun run desktop:quality:build && bun run desktop:quality:test --update-snapshots && bun apps/desktop/quality-gates/syncProductScreenshot.ts",
    "desktop:quality:screenshot:check": "bun apps/desktop/quality-gates/syncProductScreenshot.ts --check",
    "desktop:quality:proof": "bun apps/desktop/quality-gates/verifyFailureProofs.ts",
    "app:mobile:dev": "cd apps/mobile && npx expo start --dev-client",
    "app:mobile:ios": "cd apps/mobile && npx expo run:ios",
    "app:mobile:android": "cd apps/mobile && npx expo run:android",
    "app:mobile:xcode": "bun scripts/open_xcode_workspace.ts",
    "app:mobile:typecheck": "cd apps/mobile && bun run typecheck",
    "build:desktop-resources": "bun scripts/build_desktop_resources.ts",
    "docs:check": "bun packages/harness/src/check_docs.ts",
    "docs:generate-jsonrpc": "bun packages/harness/src/generate_ws_jsonrpc_schema.ts",
    "harness:run": "bun packages/harness/src/run_raw_agent_loops.ts --report-only",
    "test": "bun scripts/run_tests.ts",
    "clean": "bun scripts/clean.ts",
    "typecheck": "bunx tsc --noEmit && bun run --cwd packages/harness typecheck && bunx tsc --noEmit -p apps/desktop/tsconfig.json",
    "typecheck:desktop": "bunx tsc --noEmit -p apps/desktop/tsconfig.json",
    "lint": "bunx biome lint .",
    "format": "bunx biome format .",
    "format:write": "bunx biome format --write .",
    "check": "bunx biome check .",
    "check:write": "bunx biome check --write .",
    "knip": "knip --no-config-hints"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.1088.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1088.0",
    "@earendil-works/pi-ai": "0.80.7",
    "@google/genai": "2.12.0",
    "@langfuse/otel": "^5.9.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@peculiar/x509": "^2.0.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/bun": "10.65.0",
    "docx": "^9.7.1",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^5.10.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "partial-json": "^0.1.7",
    "posthog-node": "5.44.0",
    "proxy-agent": "^8.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "remark-parse": "^11.0.0",
    "turndown": "^7.2.4",
    "unified": "^11.0.5",
    "unofficial-antigravity-sdk": "^1.0.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "yauzl": "3.4.0",
    "zod": "4.4.3"
  },
  "optionalDependencies": {
    "@microsoft/windows-ai-electron": "^0.2.0",
    "tsfm-sdk": "^0.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.4",
    "@playwright/test": "^1.61.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@types/yauzl": "^3.4.0",
    "bun-types": "^1.3.14",
    "fake-indexeddb": "^6.2.5",
    "knip": "^6.27.0",
    "typescript": "^7.0.2"
  }
}
