{
  "name": "agent-coworker",
  "version": "0.1.33",
  "private": true,
  "type": "module",
  "bin": {
    "cowork": "./src/index.ts"
  },
  "scripts": {
    "postinstall": "bun install --cwd apps/desktop",
    "start": "cd apps/desktop && bun run dev",
    "tui": "bun --preload @opentui/solid/preload src/tui/index.tsx",
    "cli": "bun src/index.ts --cli",
    "dev": "bun --watch src/index.ts",
    "serve": "bun src/server/index.ts",
    "build:server-binary": "bun scripts/build_cowork_server_binary.ts",
    "desktop:dev": "cd apps/desktop && bun run dev",
    "desktop:build": "cd apps/desktop && bun run build",
    "build:desktop-resources": "bun scripts/build_desktop_resources.ts",
    "docs:check": "bun scripts/check_docs.ts",
    "harness:run": "bun scripts/run_raw_agent_loops.ts --report-only",
    "test": "bun test",
    "test:stable": "bun scripts/run_tests_stable.ts",
    "typecheck": "bunx tsc --noEmit && bunx tsc --noEmit -p apps/desktop/tsconfig.json",
    "typecheck:desktop": "bunx tsc --noEmit -p apps/desktop/tsconfig.json"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@langfuse/otel": "^4.6.1",
    "@mariozechner/pi-ai": "^0.55.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentui/core": "^0.1.86",
    "@opentui/react": "^0.1.86",
    "@opentui/solid": "^0.1.86",
    "fast-glob": "^3.3.3",
    "fuzzysort": "^3.1.0",
    "jsdom": "^28.1.0",
    "partial-json": "^0.1.7",
    "react": "^19.2.4",
    "solid-js": "^1.9.11",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/turndown": "^5.0.6",
    "bun-types": "^1.3.10",
    "puppeteer-core": "^24.38.0",
    "typescript": "^5.9.3"
  }
}
