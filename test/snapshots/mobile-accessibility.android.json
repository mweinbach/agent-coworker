  "motion": {
    "reducedMotionTransform": null,
    "standardMotionTransform": "[{\"scale\":0.985}]"
  },
  "navigation": {
    "backBehavior": "history",
    "deepLinks": {
      "/threads": {
        "route": "(chats)",
        "screen": "threads/index"
      },
      "/thread/[id]": {
        "route": "(chats)",
        "screen": "thread/[id]"
      },
      "/settings": {
        "route": "(settings)",
        "screen": "settings/index"
      },
      "/settings/mcp": {
        "route": "(settings)",
        "screen": "settings/mcp"
      },
      "/settings/providers": {
        "route": "(settings)",
        "screen": "settings/providers"
      },
      "/settings/usage": {
        "route": "(settings)",
        "screen": "settings/usage"
      },
      "/skills": {
        "route": "(skills)",
        "screen": "skills/index"
      },
      "/workspace": {
        "route": "(workspace)",
        "screen": "workspace/index"
      },
      "/workspace/backups": {
        "route": "(workspace)",
        "screen": "workspace/backups"
      },
      "/workspace/general": {
        "route": "(workspace)",
        "screen": "workspace/general"
      },
      "/workspace/memory": {
        "route": "(workspace)",
        "screen": "workspace/memory"
      }
    },
    "initialTab": "(chats)",
    "scenario": {
      "activeAfterStackBack": "(workspace)",
      "activeAfterTabBack": "(settings)",
      "preservedBeforeBack": {
        "(chats)": ["threads/index"],
        "(settings)": ["settings/index", "settings/providers"],
        "(skills)": ["skills/index"],
        "(workspace)": ["workspace/index", "workspace/general"]
      },
      "stateAfterBack": {
        "(chats)": ["threads/index"],
        "(settings)": ["settings/index", "settings/providers"],
        "(skills)": ["skills/index"],
        "(workspace)": ["workspace/index"]
      }
    },
    "stacks": {
      "(chats)": ["threads/index", "thread/[id]"],
      "(settings)": ["settings/index", "settings/providers", "settings/mcp", "settings/usage"],
      "(skills)": ["skills/index"],
      "(workspace)": [
        "workspace/index",
        "workspace/general",
        "workspace/memory",
        "workspace/backups"
      ]
    },
    "tabs": [
      {
        "badge": "2",
        "icon": {
          "default": "forum",
          "selected": "forum"
        },
        "label": "Chats",
        "route": "(chats)"
      },
      {
        "badge": null,
        "icon": {
          "default": "folder",
          "selected": "folder"
        },
